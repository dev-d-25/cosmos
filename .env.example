# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Database (Neon Postgres — https://console.neon.tech)
# Copy the *pooled* connection string from your Neon project dashboard.
# The "-pooler" hostname is required for serverless / Vercel deployments
# because it handles many short-lived connections. For local migrations
# you can swap in the direct (non-pooler) URL.
#
# Example format:
# DATABASE_URL="postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
DATABASE_URL=""

# Corsair
# Generate with: openssl rand -base64 32
CORSAIR_KEK=""

APP_URL=http://localhost:3000

# Kilo AI Gateway (https://kilo.ai) — free models only
# Sign up, then create an API key at https://app.kilo.ai/profile
KILO_API_KEY=""
KILO_DEFAULT_MODEL="kilo-auto/free"
