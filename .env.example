# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Database (Postgres)
DATABASE_URL="postgresql://postgres:password@localhost:5432/corsair"

# Corsair
# Generate with: openssl rand -base64 32
CORSAIR_KEK=""

APP_URL=http://localhost:3000

# Kilo AI Gateway (https://kilo.ai) — free models only
# Sign up, then create an API key at https://app.kilo.ai/profile
KILO_API_KEY=""
KILO_DEFAULT_MODEL="kilo-auto/free"
